#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        layer_0 {
            bindings = <
&kp TAB         &kp Q         &kp W      &kp E                &kp R      &kp T                                   &kp Y     &kp U      &kp I      &kp O    &kp P            &kp LBKT
&kp LCTRL       &kp A         &kp S      &kp D                &kp F      &kp G          &kp DOWN    &kp RIGHT    &kp H     &kp J      &kp K      &kp L    &kp LBKT         &kp RBKT
&kp LEFT_SHIFT  &kp Z         &kp X      &kp C                &kp V      &kp B          &kp K_COPY  &kp K_PASTE  &kp N     &kp M      &kp COMMA  &kp DOT  &kp SLASH        &kp BACKSLASH
&kp LEFT_ALT    &kp LEFT_WIN  &kp SPACE  &kp INTERNATIONAL_4  &kp ENTER  &kp BACKSPACE                           &mkp MB1  &mkp RCLK                      &kp RIGHT_SHIFT  &kp RCTRL
&kp ESC         &kp N1        &kp N2     &kp N3               &kp N4     &kp N5         &kp UP      &kp LEFT     &kp N6    &kp N7     &kp N8     &kp N9   &kp N0           &kp MINUS
            >;
        };

        layer_1 {
            bindings = <
&none  &none  &none  &none  &none  &none                &none  &none  &none  &none  &none  &none
&none  &none  &none  &none  &none  &none  &none  &none  &none  &none  &none  &none  &none  &none
&none  &none  &none  &none  &none  &none  &none  &none  &none  &none  &none  &none  &none  &none
&none  &none  &none  &none  &none  &none                &none  &none                &none  &none
&none  &none  &none  &none  &none  &none  &none  &none  &none  &none  &none  &none  &none  &none
            >;
        };
    };
};
