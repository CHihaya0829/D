#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

/ {
    behaviors {
        N2_DQT: N2_DQT {
            compatible = "zmk,behavior-mod-morph";
            label = "N2_DQT";
            bindings = <&kp KP_NUMBER_2>, <&kp DQT>;

            #binding-cells = <0>;
            mods = <(MOD_RSFT|MOD_LSFT)>;
        };

        H6_AMPS: H6_AMPS {
            compatible = "zmk,behavior-mod-morph";
            label = "H6_AMPS";
            bindings = <&kp KP_N6>, <&kp AMPS>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT|MOD_RSFT)>;
        };

        N7_SQT: N7_SQT {
            compatible = "zmk,behavior-mod-morph";
            label = "N7_SQT";
            bindings = <&kp KP_N7>, <&kp SQT>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT|MOD_RSFT)>;
        };

        N8_LPAR: N8_LPAR {
            compatible = "zmk,behavior-mod-morph";
            label = "N8_LPAR";
            bindings = <&kp KP_N8>, <&kp LPAR>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT|MOD_RSFT)>;
        };

        N9_RPAR: N9_RPAR {
            compatible = "zmk,behavior-mod-morph";
            label = "N9_RPAR";
            bindings = <&kp KP_N9>, <&kp RPAR>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT|MOD_RSFT)>;
        };

        N0_AT: N0_AT {
            compatible = "zmk,behavior-mod-morph";
            label = "N0_AT";
            bindings = <&kp KP_N0>, <&kp AT>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT|MOD_RSFT)>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        layer_0 {
            bindings = <
&kp TAB         &kp Q         &kp W      &kp E                &kp R      &kp T                                   &kp Y      &kp U      &kp I      &kp O     &kp P            &kp SEMICOLON
&kp LCTRL       &kp A         &kp S      &kp D                &kp F      &kp G          &kp DOWN    &kp RIGHT    &kp H      &kp J      &kp K      &kp L     &kp LBKT         &kp RBKT
&kp LEFT_SHIFT  &kp Z         &kp X      &kp C                &kp V      &kp B          &kp K_COPY  &kp K_PASTE  &kp N      &kp M      &kp COMMA  &kp DOT   &kp SLASH        &kp BACKSLASH
&kp LEFT_ALT    &kp LEFT_WIN  &kp SPACE  &kp INTERNATIONAL_4  &kp ENTER  &kp BACKSPACE                           &mkp LCLK  &mkp RCLK                       &kp RIGHT_SHIFT  &kp RCTRL
&kp ESC         &kp N1        &N2_DQT    &kp N3               &kp N4     &kp N5         &kp UP      &kp LEFT     &H6_AMPS   &N7_SQT    &N8_LPAR   &N9_RPAR  &N0_AT           &kp MINUS
            >;
        };

        layer_1 {
            bindings = <
&none  &none  &none  &none  &none  &none                &none  &none  &none  &none  &none  &none
&none  &none  &none  &none  &none  &none  &none  &none  &none  &none  &none  &none  &none  &none
&none  &none  &none  &none  &none  &none  &none  &none  &none  &none  &none  &none  &none  &none
&none  &none  &none  &none  &none  &none                &none  &none                &none  &none
&none  &none  &none  &none  &none  &none  &none  &none  &none  &none  &none  &none  &none  &none
            >;
        };
    };
};
